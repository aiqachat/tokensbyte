# TokensByte 后端配置文件模板
# 复制此文件为 .env 并根据需要修改配置

# 1. 服务运行配置
# 监听地址
HOST=0.0.0.0
# 监听端口
PORT=3000

# 2. 数据库配置
# PostgreSQL 示例: postgres://username:password@host:port/database
# SQLite 示例: sqlite:./data/tokensbyte.db
DATABASE_URL=postgres://tokensapi:tokensapi@localhost:5432/tokensapi

# 3. 安全配置
# 必填：JWT 签名密钥，请务必修改为一个随机的长字符串
JWT_SECRET=tokensbyte-change-me-for-security
# 必填：用于加密渠道 API Key 的密钥，必须是 32 位字符
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# 4. 初始管理员配置
# 第一次启动时创建的管理员账号
ADMIN_USERNAME=admin
# 第一次启动时创建的管理员密码
ADMIN_PASSWORD=123456

# 5. 业务逻辑配置
# 是否允许用户注册
REGISTER_ENABLED=true
# 注册时默认赠送的额度 (单位：1元)
DEFAULT_USER_QUOTA=0
