# TokensByte 环境变量配置
# ──────────────────────────────────────────────────
# 项目名称配置 (可选，默认为当前目录名)
PROJECT_NAME=tokensbyte-ws

# 数据库连接 (二选一，解开注释即可)
# ──────────────────────────────────────────────────

# [1. 内置 PostgreSQL (默认，开箱即用)]
DATABASE_URL=postgres://tokensapi:tokensapi@postgres:5432/tokensapi

# [2. 外部 PostgreSQL (RDS/云数据库)]
# DATABASE_URL=postgres://用户名:密码@数据库地址:5432/数据库名?sslmode=disable

# ──────────────────────────────────────────────────
# 内置 PostgreSQL 配置 (使用外部数据库时可忽略)
# ──────────────────────────────────────────────────
POSTGRES_USER=tokensapi
POSTGRES_PASSWORD=tokensapi
POSTGRES_DB=tokensapi

# ──────────────────────────────────────────────────
# 安全配置 (生产环境务必修改)
# ──────────────────────────────────────────────────
# 使用命令"openssl rand -hex 32"生成JWT_SECRET
JWT_SECRET=tokensbyte-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ──────────────────────────────────────────────────
# 端口配置
# ──────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=8080
POSTGRES_PORT=5432

# ──────────────────────────────────────────────────
# 客户端最大请求体限制 (如上传素材的最大限制，默认 50m)
# ──────────────────────────────────────────────────
CLIENT_MAX_BODY_SIZE=50m

# ──────────────────────────────────────────────────
# 功能开关
# ──────────────────────────────────────────────────
REGISTER_ENABLED=true

# ──────────────────────────────────────────────────
# 日志级别
# ──────────────────────────────────────────────────
RUST_LOG=info

# ──────────────────────────────────────────────────
# 数据目录 (存储图标、素材等静态文件)
# Docker 部署时由 docker-compose 自动设置，无需手动修改
# 本地开发时默认为 'data'（相对于后端工作目录）
# ──────────────────────────────────────────────────
# DATA_DIR=data
