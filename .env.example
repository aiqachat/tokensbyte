# TokensByte 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==========================================
# 数据库配置
# ==========================================

# PostgreSQL 连接字符串（生产环境推荐）
# 格式：postgres://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgres://tokensbyte:your_secure_password@postgres:5432/tokensbyte

# PostgreSQL 密码（用于 docker-compose 初始化）
POSTGRES_PASSWORD=your_secure_password

# 如果使用 SQLite（仅用于开发测试）
# DATABASE_URL=sqlite://data/tokensbyte.db

# ==========================================
# 安全配置
# ==========================================

# JWT 密钥（生产环境必须修改为强随机字符串）
# 建议：使用 `openssl rand -hex 32` 生成
JWT_SECRET=your-secret-key-change-me-in-production

# ==========================================
# 管理员账号配置
# ==========================================

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员密码（生产环境必须修改）
ADMIN_PASSWORD=your-admin-password

# ==========================================
# 服务端口配置
# ==========================================

# 后端服务端口
BACKEND_PORT=3000

# 前端服务端口
FRONTEND_PORT=5173

# ==========================================
# 功能开关
# ==========================================

# 是否允许用户注册（生产环境建议关闭）
REGISTER_ENABLED=true

# ==========================================
# 可选配置
# ==========================================

# 服务绑定地址（Docker 环境使用 0.0.0.0）
HOST=0.0.0.0

# 后端服务端口（容器内部）
PORT=3000

# 日志级别（trace, debug, info, warn, error）
RUST_LOG=info

# ==========================================
# 生产环境检查清单
# ==========================================
# [ ] 修改 JWT_SECRET 为强随机字符串
# [ ] 修改 ADMIN_PASSWORD 为强密码
# [ ] 设置 REGISTER_ENABLED=false（如不需要公开注册）
# [ ] 使用 PostgreSQL 而非 SQLite
# [ ] 配置 HTTPS（通过 Nginx 反向代理）
# [ ] 定期备份数据库
